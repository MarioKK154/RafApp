<script type="aaa65416e23dca4f85a8450b-text/javascript">
const cta = document.querySelector('.cta-hero');
const content = document.querySelector('.page-hero-block__content');
if (cta && content) {
  const height = cta.offsetHeight;
  
  if (window.innerWidth < 992) {
    content.style.marginTop = `${height - 50}px`;
  } else {
    content.style.marginTop = `${height}px`;
  }
  
  // Update on resize
  window.addEventListener('resize', () => {
    const newHeight = cta.offsetHeight;
    if (window.innerWidth < 992) {
      content.style.marginTop = `${newHeight - 50}px`;
    } else {
      content.style.marginTop = `${newHeight}px`;
    }
  });
}
</script>

  



<div class="img-text-block img-text-block--portrait  container">
    <div class="img-text-block--content">
        
<div class="portrait-img-text-block--text-content title-content-cta">
    
      <h1 class="headlines-5">Fjölbreyttar lausnir fyrir rafiðnaðinn</h1>
    
    
    
      <div class="body-3 custom-text-block"><p data-block-key="rynbk">Johan Rönning er leiðandi heildverslun í rafmagns- og tækniiðnaði, sem þjónustar aðallega fagmarkaðinn. Fyrirtækið býður fjölbreytt úrval af rafmagns- og lagnakerfum, netbúnaði, hitalausnum, lýsingar- og öryggisbúnaði, auk sérhæfðra stýri- og hússtjórnarkerfa. Johan Rönning leggur áherslu á gæðavörur, faglega ráðgjöf og sérhæfða þjónustu fyrir fjölbreyttar framkvæmdir um allt land.</p></div>
    
    
    
  </div>
