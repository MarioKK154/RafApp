<script type="aaa65416e23dca4f85a8450b-text/javascript">
    /**
      Alpine js logic for adding tooltip on hover
      To call tooltip use this configuration on element: 
        x-tooltip="'Some tooltip text'" 
        x-data={open: false}
        class="position-relative"
    */
    document.addEventListener('alpine:init', () => {
      // Define the x-tooltip directive
      Alpine.directive('tooltip', (el, { expression }, { evaluate }) => {
        const tooltipText = evaluate(expression);

        // Initialize Alpine.js component state
        el.setAttribute('x-data', '{ show: false, tooltipText: "' + tooltipText.replace(/"/g, '\\"') + '" }');
        el.setAttribute('x-on:mouseenter', 'show = true');
        el.setAttribute('x-on:mouseleave', 'show = false');

        // Create the tooltip element
        const tooltip = document.createElement('div');
        tooltip.className = 'tooltip-hover';
        tooltip.setAttribute('x-show', 'show');
        tooltip.setAttribute('x-text', 'tooltipText');
        tooltip.setAttribute('x-transition:enter', 'transition ease-out duration-200');
        tooltip.setAttribute('x-transition:enter-start', 'opacity-0 translate-y-2');
        tooltip.setAttribute('x-transition:enter-end', 'opacity-100 translate-y-0');
        tooltip.setAttribute('x-transition:leave', 'transition ease-in duration-150');
        tooltip.setAttribute('x-transition:leave-start', 'opacity-100 translate-y-0');
        tooltip.setAttribute('x-transition:leave-end', 'opacity-0 translate-y-2');

        // Append the tooltip to the element
        el.appendChild(tooltip);
      });
    });

    const MEGA_MENU_SCROLL_THRESHOLD = 15;
    const MEGA_MENU_TOP_DEFAULT = '98px';
    const MEGA_MENU_TOP_SCROLLED = '70px';

    const updateDesktopMegaMenuTop = () => {
      const desktopNav = document.getElementById('nav_not_scroll');
      if (!desktopNav) {
        return;
      }
      const nextValue = window.scrollY > MEGA_MENU_SCROLL_THRESHOLD
        ? MEGA_MENU_TOP_SCROLLED
        : MEGA_MENU_TOP_DEFAULT;
      if (desktopNav.style.getPropertyValue('--desktop-mega-menu-top') !== nextValue) {
        desktopNav.style.setProperty('--desktop-mega-menu-top', nextValue);
      }
    };

    document.addEventListener('DOMContentLoaded', () => {
      updateDesktopMegaMenuTop();
      window.addEventListener('scroll', updateDesktopMegaMenuTop, { passive: true });
      window.addEventListener('resize', updateDesktopMegaMenuTop);
    });
</script>

