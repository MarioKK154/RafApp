<script type="aaa65416e23dca4f85a8450b-text/javascript">
(function() {
  // Find the most recently added carousel container (this one)
  var containers = document.querySelectorAll('.specials-carousel-container');
  var container = containers[containers.length - 1];

  if (!container || container.hasAttribute('data-swiper-init')) return;
  container.setAttribute('data-swiper-init', 'true');

  var carouselEl = container.querySelector('.specials-swiper');
  var prevBtn = container.querySelector('.swiper-button-prev');
  var nextBtn = container.querySelector('.swiper-button-next');
  var pagination = container.querySelector('.swiper-pagination');

  if (!carouselEl) return;

  function initSwiper() {
    var width = window.innerWidth;
    var slidesPerView, spaceBetween;

    if (width >= 1200) {
      slidesPerView = 5;
      spaceBetween = 30;
    } else if (width >= 992){
      slidesPerView = 4;
      spaceBetween = 20;
    } else if (width >= 768) {
      slidesPerView = 3;
      spaceBetween = 20;
    } else {
      slidesPerView = 2;
      spaceBetween = 10;
    }

    if (carouselEl.swiper) {
      carouselEl.swiper.destroy(true, true);
    }

    new Swiper(carouselEl, {
      slidesPerView: slidesPerView,
      spaceBetween: spaceBetween,
      direction: 'horizontal',
      loop: true,
      navigation: {
        nextEl: nextBtn,
        prevEl: prevBtn,
      },
      pagination: {
        el: pagination,
        clickable: true,
      },
    });
  }

  initSwiper();

  var resizeHandler = function() {
    initSwiper();
  };
  window.addEventListener('resize', resizeHandler);
})();
</script>



