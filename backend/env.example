# Copy to .env and adjust. Target scale: ~5000 users across ~80 tenants (companies).

# --- Host tomorrow (single PostgreSQL — recommended now) ---
# 1) On the server: create ONE database (e.g. rafapp) and a non-superuser role with a strong password.
# 2) Set DATABASE_URL below to that database only.
# 3) Do NOT set DATABASE_URL_REGISTRY / _SHOP / _REFERENCE until you intentionally split DBs and add migrations per DB.
# 4) On a machine with this repo + .env:  cd backend
#      pip install -r requirements.txt
#      alembic upgrade head
#      python scripts/verify_production_database.py
# 5) Local same shape as prod:  docker compose up -d
#      DATABASE_URL=postgresql+psycopg2://rafapp:rafapp_local@127.0.0.1:5432/rafapp
#      REDIS_URL=redis://127.0.0.1:6379/0

# --- Core ---
APP_ENV=development
# APP_ENV=production

# Primary DB: all app data today. Use PostgreSQL in production.
DATABASE_URL=postgresql+psycopg2://USER:PASSWORD@HOST:5432/rafapp

# Optional logical split (only after you create extra databases and migration pipelines).
# DATABASE_URL_REGISTRY=postgresql+psycopg2://USER:PASSWORD@HOST:5432/rafapp_registry
# DATABASE_URL_SHOP=postgresql+psycopg2://USER:PASSWORD@HOST:5432/rafapp_shop
# DATABASE_URL_REFERENCE=postgresql+psycopg2://USER:PASSWORD@HOST:5432/rafapp_reference

# Pool sizing: under PgBouncer (transaction mode), keep pool_size modest per process.
# Example: 4 API workers × pool_size 20 ≈ 80 server connections; PgBouncer multiplexes clients.
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40
DB_POOL_RECYCLE=1800
DB_POOL_TIMEOUT=30

# --- Multi-instance / load balancer ---
# Set in production so rate limits apply across all API replicas (SlowAPI + Redis).
# REDIS_URL=redis://localhost:6379/0

# --- HTTP ---
# Comma-separated browser origins (your SPA / admin URLs).
# CORS_ORIGINS=https://app.example.com,https://admin.example.com

# Optional: restrict Host header (production). Comma-separated.
# TRUSTED_HOSTS=app.example.com,api.example.com
